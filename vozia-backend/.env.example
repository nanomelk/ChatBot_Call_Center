# Configuración de VozIA Backend
# Copiar este archivo a .env y ajustar según necesidades

# ========== APLICACIÓN ==========
DEBUG=True
API_TITLE=VozIA API
API_VERSION=1.0.0

# ========== OPENAI (OPCIONAL) ==========
# OPENAI_API_KEY=sk-xxx

# ========== BASE DE DATOS ==========
DATABASE_URL=sqlite:///./vozia.db
MONGO_URI=mongodb+srv://voziademo:<db_password>@voziadb.ges0u81.mongodb.net/?appName=VozIAdb
MONGO_DB_NAME=VozIAdb

# ========== CORS ==========
CORS_ORIGINS=["*"]

# ========== RUTAS ==========
UPLOAD_DIR=uploads

# OLLAMA MODEL
OLLAMA_MODEL=your-model-name